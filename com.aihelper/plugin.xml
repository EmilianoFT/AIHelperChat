<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>

<plugin>

   <extension
         point="org.eclipse.ui.views">
      <category
            id="com.aihelper.ui.category"
            name="AI Helper"
            parentCategory="org.eclipse.ui">
   	</category>
      <view
            id="com.aihelper.ui.chatView"
            name="AI Helper Chat"
            class="com.aihelper.ui.ChatView"
            category="com.aihelper.ui.category"
            icon="$nl$/icons/aihelper-icon.png">
      </view>
   </extension>
   
   <extension
         point="org.eclipse.core.runtime.preferences">
      <initializer
            class="com.aihelper.preferences.PreferenceInitializer">
      </initializer>
   </extension>

   <extension
         point="org.eclipse.ui.preferencePages">
      <page
            category="com.aihelper.preferences"
            class="com.aihelper.preferences.CredentialsPreferencePage"
            id="com.aihelper.preferences"
            name="AI Helper Chat">
      </page>
   </extension>

</plugin>
